ADP_SERVER_ADDR=:8080
ADP_WORKER_GRPC_ADDR=:9090
ADP_AUTH_SECRET=<set-in-secret-manager>
ADP_ADMIN_USERNAME=admin
ADP_ADMIN_PASSWORD=<set-in-secret-manager>
# Server: ADP_AUTH_WORKER_TOKEN; standalone Worker: ADP_WORKER_TOKEN.
ADP_AUTH_WORKER_TOKEN=<set-in-secret-manager>
ADP_WORKER_TOKEN=<set-in-secret-manager>
ADP_SERVER_URL=http://127.0.0.1:8080
ADP_GRPC_SERVER_ADDR=127.0.0.1:9090
ADP_WORKER_NAME=worker-1
ADP_WORKER_TYPE=shell
ADP_WORKER_POLL_INTERVAL=5s
ADP_SERVICES_CONFIG=/etc/adp/services.cnf
# LLM 配置 (可选，不配置则使用规则匹配)
ADP_LLM_BASE_URL=https://api.openai.com/v1
ADP_LLM_API_KEY=<set-in-secret-manager-or-leave-empty>
ADP_LLM_MODEL=gpt-4
ADP_AI_CONTEXT=configs/ai/ai_context.yaml
