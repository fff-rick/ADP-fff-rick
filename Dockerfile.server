ARG GO_VERSION=1.25.0

FROM golang:${GO_VERSION}-alpine AS build

WORKDIR /src
RUN apk add --no-cache git ca-certificates

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags="-s -w" -o /out/adp-server ./cmd/server

FROM alpine:3.22

RUN apk add --no-cache ca-certificates tzdata
COPY --from=build /out/adp-server /usr/local/bin/adp-server

EXPOSE 8080 9090
ENTRYPOINT ["adp-server"]
CMD ["serve"]
