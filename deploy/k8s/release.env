# Update ADP_IMAGE_TAG in a PR to control the image version built and deployed.
ADP_IMAGE_TAG=0.1.0

# Optional: set a registry prefix when the cluster should pull images from a registry.
# Example: ADP_IMAGE_REPOSITORY_PREFIX=registry.example.com/adp
ADP_IMAGE_REPOSITORY_PREFIX=

# Optional: set to true when ADP_IMAGE_REPOSITORY_PREFIX points to a pushable registry.
ADP_PUSH_IMAGES=false
